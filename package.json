{
  "name": "ai-commit-plus",
  "displayName": "AI Commit Plus",
  "description": "Use OpenAI and Gemini APIs to review Git changes, generate conventional commit messages, and keep commit conventions consistent with the AI Commit Plus workflow.",
  "version": "0.3.8",
  "engines": {
    "node": ">=24",
    "vscode": "^1.77.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "Azure",
    "OpenAI",
    "ChatGPT",
    "GitEmoji",
    "Git Commit",
    "Conventional Commits",
    "Commitizen",
    "Commit Message",
    "Commit Message Generator",
    "AI Commit Plus",
    "Auto Commit"
  ],
  "publisher": "mizuikki",
  "repository": "https://github.com/mizuikki/ai-commit-plus",
  "icon": "images/logo.png",
  "contributes": {
    "commands": [
      {
        "command": "extension.ai-commit-plus",
        "icon": {
          "dark": "images/icon.svg",
          "light": "images/icon.svg"
        },
        "title": "AI Commit Plus"
      },
      {
        "command": "ai-commit-plus.showAvailableModels",
        "title": "Show Available OpenAI Models"
      },
      {
        "command": "ai-commit-plus.setCommitLanguageForCurrentRepository",
        "title": "Set Commit Language for Current Repository"
      },
      {
        "command": "ai-commit-plus.setPromptPresetForCurrentRepository",
        "title": "Set Prompt Preset for Current Repository"
      },
      {
        "command": "ai-commit-plus.manageProviderProfiles",
        "title": "Manage Provider Profiles"
      },
      {
        "command": "ai-commit-plus.switchProviderProfile",
        "title": "Switch Provider Profile"
      }
    ],
    "configuration": {
      "properties": {
        "ai-commit-plus.AI_COMMIT_LANGUAGE": {
          "default": "English",
          "markdownDescription": "Default commit message language. This setting supports repository-level overrides through workspace or folder settings.",
          "scope": "resource",
          "enum": [
            "Simplified Chinese",
            "Traditional Chinese",
            "Japanese",
            "Korean",
            "Czech",
            "German",
            "French",
            "Italian",
            "Dutch",
            "Portuguese",
            "Vietnamese",
            "English",
            "Spanish",
            "Swedish",
            "Russian",
            "Bahasa",
            "Polish",
            "Turkish",
            "Thai"
          ],
          "enumDescriptions": [
            "简体中文",
            "繁體中文",
            "にほんご",
            "한국어",
            "česky",
            "Deutsch",
            "française",
            "italiano",
            "Nederlands",
            "português",
            "tiếng Việt",
            "english",
            "español",
            "Svenska",
            "русский",
            "bahasa",
            "Polski",
            "Turkish",
            "ไทย"
          ],
          "type": "string"
        },
        "ai-commit-plus.PROMPT_PRESET": {
          "type": "string",
          "default": "without-gitmoji",
          "scope": "resource",
          "markdownDescription": "Prompt preset for commit generation. This setting supports repository-level overrides through workspace or folder settings.",
          "enum": [
            "with-gitmoji",
            "without-gitmoji",
            "custom"
          ],
          "enumDescriptions": [
            "Generate emoji-prefixed Conventional Commit messages",
            "Generate Conventional Commit messages without emojis",
            "Use AI_COMMIT_SYSTEM_PROMPT as the full custom system prompt"
          ]
        },
        "ai-commit-plus.AI_COMMIT_SYSTEM_PROMPT": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Custom system prompt for generating commit messages"
        },
        "ai-commit-plus.PROVIDER_PROFILES": {
          "type": "array",
          "default": [],
          "description": "Stored provider profiles. API keys are stored separately in VS Code SecretStorage.",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "openai-compatible",
                  "gemini"
                ]
              },
              "baseURL": {
                "type": "string"
              },
              "model": {
                "type": "string"
              },
              "temperature": {
                "type": "number"
              },
              "azureApiVersion": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "name",
              "type",
              "model"
            ]
          }
        },
        "ai-commit-plus.ACTIVE_PROVIDER_PROFILE_ID": {
          "type": "string",
          "default": "",
          "description": "Active provider profile id. Can be overridden per workspace or repository."
        },
        "ai-commit-plus.DEBUG_LOGGING": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "markdownDescription": "Enable debug logs for troubleshooting. Logs are written to the \"AI Commit Plus\" Output channel. Avoid enabling this in shared workspaces if you consider repository metadata sensitive."
        },
        "ai-commit-plus.MAX_DIFF_CHARS": {
          "type": "number",
          "default": 200000,
          "scope": "resource",
          "markdownDescription": "Maximum number of characters allowed in the staged diff sent to the provider. If exceeded, AI Commit Plus will ask you to split the commit into smaller chunks."
        }
      },
      "title": "AI Commit Plus"
    },
    "menus": {
      "scm/title": [
        {
          "command": "extension.ai-commit-plus",
          "group": "navigation"
        }
      ]
    }
  },
  "main": "./dist/extension.js",
  "scripts": {
    "build": "webpack --mode production --devtool hidden-source-map",
    "compile": "webpack",
    "compile-tests": "node -e \"require('node:fs').rmSync('out/test', { recursive: true, force: true })\" && tsc -p tsconfig.test.json",
    "lint": "eslint src --ext ts",
    "package": "node ./scripts/vsix.js package",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "publish": "npm run package && node ./scripts/vsix.js publish",
    "test": "node ./out/test/runTest.js",
    "vscode:prepublish": "npm run build",
    "watch": "webpack --watch",
    "watch-tests": "tsc -p tsconfig.test.json -w"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.77.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/vsce": "^3.9.0",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^8.57.0",
    "glob": "^8.1.0",
    "mocha": "^10.8.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.0",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "fs-extra": "^11.0.4",
    "gitmojis": "^3.15.0",
    "openai": "^4.14.2",
    "simple-git": "^3.17.0"
  },
  "resolutions": {
    "@types/node": "24.x"
  },
  "license": "MIT"
}
